{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "rootDir": ".",
        "outDir": "dist-server",
        "noEmit": false,
        "allowImportingTsExtensions": false,
        "isolatedModules": false,
        "useDefineForClassFields": false,
        "types": ["node"]
    },
    "include": ["src/server/**/*.ts"]
}
